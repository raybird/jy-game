{
  "compilerOptions": {
    "checkJs": true,
    "strict": false,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "alwaysStrict": true,
    "allowJs": true,
    "module": "ES2020",
    "moduleResolution": "bundler",
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "noEmit": true,
    "skipLibCheck": true,
    "maxNodeModuleJsDepth": 0,
    "suppressExcessPropertyErrors": true,
    "ignoreDeprecations": "5.0",
    "useUnknownInCatchVariables": false
  },
  "include": ["src/**/*.js"],
  "exclude": ["node_modules", "dist"]
}